# Example environment variables for ai-services-directory
# Copy this to .env (do NOT commit secrets to git) and set real values in production.

# Node environment
NODE_ENV=production

# Server port (optional)
PORT=3000

# Frontend origin (set to your production site)
FRONTEND_URL=https://aientity.co.uk

# Optional: additional allowed origins (comma-separated)
FRONTEND_ORIGINS=

# Optional: cookie domain to allow cookie across subdomains
COOKIE_DOMAIN=.aientity.co.uk

# Railway static url (if using Railway static hosting)
RAILWAY_STATIC_URL=

# JWT secret (replace in production with a secure value)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Note: This project uses a local SQLite DB by default (data/ai-services.db).
# If you switch to an external DB, add DATABASE_URL here.
